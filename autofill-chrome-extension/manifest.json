{
  "manifest_version": 3,
  "name": "Job Autofill (Cowork)",
  "version": "0.1.0",
  "description": "Autofills job applications when triggered by Cowork via body data attributes.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Autofill (Cowork)"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://ats.rippling.com/*"],
      "js": ["bridge-main.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["candidate-data.json", "selector-overrides.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
